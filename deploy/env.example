# OpenClaw state directory (default: ~/.openclaw)
OPENCLAW_STATE_DIR=/home/pi/.openclaw

# HomeBot HTTP server port
HOMEBOT_PORT=8080

# OpenClaw Gateway port (for health checks)
OPENCLAW_GATEWAY_PORT=18789

# Gateway auth token — install script extracts from openclaw.json
GATEWAY_TOKEN=replace-me

# Kiosk start URL (token in fragment)
KIOSK_URL=http://127.0.0.1:8080/#token=replace-me

# Dedicated Chromium profile (single instance; do not launch chromium manually)
# HOMEBOT_KIOSK_PROFILE=$HOME/.config/homebot-kiosk

# Display for Chromium kiosk (Pi desktop)
DISPLAY=:0
